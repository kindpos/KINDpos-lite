{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "KINDpos",
    "version": "1.3.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "identifier": "com.kindpos.lite",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "resources/**/*"
      ],
      "targets": [
        "msi",
        "nsis"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "language": "en-US"
        }
      }
    },
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:*; connect-src http://127.0.0.1:* ws://127.0.0.1:*; style-src 'self' 'unsafe-inline' http://127.0.0.1:*; font-src 'self' http://127.0.0.1:*; img-src 'self' http://127.0.0.1:* data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://127.0.0.1:*",
      "dangerousRemoteDomainIpcAccess": [
        {
          "scheme": "http",
          "domain": "127.0.0.1",
          "windows": ["main"],
          "enableTauriAPI": false
        }
      ]
    },
    "windows": [
      {
        "title": "KINDpos",
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "width": 1024,
        "height": 600,
        "url": "about:blank"
      }
    ]
  }
}
